rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Helpers
    function isValidUser(data) {
      return data.get('uid', request.auth.uid) == request.auth.uid &&
             (data.get('email', '') is string && data.get('email', '').size() <= 256) &&
             (data.get('displayName', '') is string && data.get('displayName', '').size() <= 256) &&
             (data.get('currency', 'VND') in ['VND', 'USD', 'EUR', 'k-VND']) &&
             (data.get('monthlyBudget', 0) is number) &&
             (data.get('editPassword', null) == null || (data.editPassword is string && data.editPassword.size() <= 64)) &&
             (data.get('createdAt', null) == null || data.createdAt is timestamp || data.createdAt is string) &&
             (data.get('migratedToKUnits', false) is bool);
    }

    function isValidTransaction(data) {
      return data.get('userId', request.auth.uid) == request.auth.uid &&
             (data.get('amount', 0) is number && data.get('amount', 0) >= 0) &&
             (data.get('type', 'expense') in ['income', 'expense']) &&
             (data.get('date', request.time) is timestamp) &&
             (data.get('category', '') is string && data.get('category', '').size() <= 100) &&
             (data.get('note', '') is string && data.get('note', '').size() <= 1000) &&
             (data.get('debtId', null) == null || isValidId(data.debtId)) &&
             (data.get('fundId', null) == null || isValidId(data.fundId)) &&
             (data.get('isTransfer', false) is bool);
    }

    function isValidDebt(data) {
      return data.get('userId', request.auth.uid) == request.auth.uid &&
             (data.get('title', '') is string && data.get('title', '').size() <= 200) &&
             (data.get('totalAmount', 0) is number && data.get('totalAmount', 0) >= 0) &&
             (data.get('remainingAmount', 0) is number && data.get('remainingAmount', 0) >= 0) &&
             (data.get('status', 'active') in ['active', 'paid']) &&
             (data.get('startDate', request.time) is timestamp) &&
             (data.get('lender', '') is string && data.get('lender', '').size() <= 200) &&
             (data.get('principalAmount', 0) is number) &&
             (data.get('category', '') is string && data.get('category', '').size() <= 100) &&
             (data.get('totalPeriods', 0) is number) &&
             (data.get('completedPeriods', 0) is number) &&
             (data.get('monthlyInstallment', 0) is number) &&
             (data.get('endDate', null) == null || data.endDate is timestamp);
    }

    function isValidSchedule(data) {
      return data.get('userId', request.auth.uid) == request.auth.uid &&
             (data.get('debtId', null) == null || isValidId(data.debtId)) &&
             (data.get('dueDate', request.time) is timestamp) &&
             (data.get('amount', 0) is number && data.get('amount', 0) >= 0) &&
             (data.get('status', 'pending') in ['pending', 'paid']) &&
             (data.get('paidAt', null) == null || data.paidAt is timestamp) &&
             (data.get('transactionId', null) == null || isValidId(data.transactionId));
    }

    function isValidFund(data) {
      return data.get('userId', request.auth.uid) == request.auth.uid &&
             (data.get('name', '') is string && data.get('name', '').size() <= 100) &&
             (data.get('type', 'consumption') in ['consumption', 'savings', 'debt', 'investment']) &&
             (data.get('balance', 0) is number) &&
             (data.get('description', '') is string && data.get('description', '').size() <= 500) &&
             (data.get('icon', '') is string && data.get('icon', '').size() <= 50) &&
             (data.get('createdAt', null) == null || data.createdAt is timestamp);
    }

    // Collection Matches
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'currency', 'monthlyBudget', 'editPassword', 'migratedToKUnits', 'uid']);

      match /transactions/{transactionId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidTransaction(incoming());
        allow update: if isOwner(userId) && isValidTransaction(incoming()) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['amount', 'type', 'category', 'note', 'date', 'fundId', 'debtId', 'isTransfer', 'userId']);
        allow delete: if isOwner(userId);
      }

      match /debts/{debtId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidDebt(incoming());
        allow update: if isOwner(userId) && isValidDebt(incoming()) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['title', 'lender', 'principalAmount', 'totalAmount', 'remainingAmount', 'monthlyInstallment', 'totalPeriods', 'completedPeriods', 'startDate', 'category', 'status', 'endDate', 'userId']);
        allow delete: if isOwner(userId);

        match /schedule/{scheduleId} {
          allow read: if isOwner(userId);
          allow create: if isOwner(userId) && isValidSchedule(incoming());
          allow update: if isOwner(userId) && isValidSchedule(incoming()) &&
                        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'paidAt', 'transactionId', 'amount', 'userId', 'debtId']);
          allow delete: if isOwner(userId);
        }
      }

      match /funds/{fundId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidFund(incoming());
        allow update: if isOwner(userId) && isValidFund(incoming()) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['balance', 'name', 'description', 'icon', 'userId']);
        allow delete: if isOwner(userId);
      }
    }
  }
}
